{
  "manifest_version": 3,
  "name": "Netfree Link Fixer",
  "version": "2.0.0",
  "description": "מתקן אוטומטית קישורים שנשברו עם תווים חוזרים עבור שירותי שיתוף קבצים",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}